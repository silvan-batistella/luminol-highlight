{
  "name": "luminol-highlight",
  "displayName": "Luminol Highlight",
  "description": "Destaque trechos de código via regex com cores customizáveis, modo Luminol forense e sidebar para gerenciamento visual.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "highlight.addPattern",
        "title": "Adicionar Highlight"
      },
      {
        "command": "highlight.removePattern",
        "title": "Remover Highlight",
        "icon": "$(trash)"
      },
      {
        "command": "highlight.editColor",
        "title": "Editar Cor",
        "icon": "$(symbol-color)"
      },
      {
        "command": "highlight.editComment",
        "title": "Editar Comentário",
        "icon": "$(comment)"
      },
      {
        "command": "highlight.goToNext",
        "title": "Ir para Próximo Match",
        "icon": "$(arrow-right)"
      },
      {
        "command": "highlight.suppressAll",
        "title": "Suprimir Highlights",
        "icon": "$(eye-closed)"
      },
      {
        "command": "highlight.unsuppressAll",
        "title": "Mostrar Highlights",
        "icon": "$(eye)"
      },
      {
        "command": "highlight.luminol",
        "title": "Ativar Luminol",
        "icon": "$(lightbulb)"
      },
      {
        "command": "highlight.luminolOff",
        "title": "Desativar Luminol",
        "icon": "$(lightbulb-autofix)"
      },
      {
        "command": "highlight.showComments",
        "title": "Mostrar Comentários",
        "icon": "$(comment)"
      },
      {
        "command": "highlight.hideComments",
        "title": "Ocultar Comentários",
        "icon": "$(comment-discussion)"
      }
    ],
    "keybindings": [
      {
        "command": "highlight.addPattern",
        "key": "ctrl+shift+h",
        "when": "editorTextFocus"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "highlight-explorer",
          "title": "Highlights",
          "icon": "resources/highlight-icon.svg"
        }
      ]
    },
    "views": {
      "highlight-explorer": [
        {
          "id": "highlightList",
          "name": "Highlight Patterns"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "highlight.hideComments",
          "when": "view == highlightList && highlight.commentsVisible",
          "group": "navigation"
        },
        {
          "command": "highlight.showComments",
          "when": "view == highlightList && !highlight.commentsVisible",
          "group": "navigation"
        },
        {
          "command": "highlight.suppressAll",
          "when": "view == highlightList && !highlight.isSuppressed",
          "group": "navigation"
        },
        {
          "command": "highlight.unsuppressAll",
          "when": "view == highlightList && highlight.isSuppressed",
          "group": "navigation"
        },
        {
          "command": "highlight.luminol",
          "when": "view == highlightList && !highlight.isLuminol",
          "group": "navigation"
        },
        {
          "command": "highlight.luminolOff",
          "when": "view == highlightList && highlight.isLuminol",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "highlight.removePattern",
          "when": "view == highlightList && viewItem == highlightEntry",
          "group": "inline"
        },
        {
          "command": "highlight.editColor",
          "when": "view == highlightList && viewItem == highlightEntry",
          "group": "inline"
        },
        {
          "command": "highlight.editComment",
          "when": "view == highlightList && viewItem == highlightEntry",
          "group": "inline"
        },
        {
          "command": "highlight.goToNext",
          "when": "view == highlightList && viewItem == highlightEntry",
          "group": "inline"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}